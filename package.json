{
  "name": "zipship-web-service",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "description": "Installable PWA that safely unzips a project and publishes it to GitHub.",
  "engines": {
    "node": ">=22.22.0 <23.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n server,client \"tsx watch src/server/index.ts\" \"vite\"",
    "typecheck": "tsc -p tsconfig.client.json && tsc -p tsconfig.server.json --noEmit",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/index.js"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "jszip": "^3.10.1",
    "multer": "^2.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  },
  "packageManager": "npm@10.9.8"
}
