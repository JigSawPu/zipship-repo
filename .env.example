# Public URL of the deployed service. On Render this can usually be omitted.
APP_URL=http://localhost:5173

# GitHub App credentials
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_SLUG=

# Base64-encoded contents of the GitHub App .pem private key
GITHUB_PRIVATE_KEY_BASE64=

# Generate with: openssl rand -base64 48
SESSION_SECRET=
SESSION_DAYS=30

# Upload limits
MAX_ZIP_MB=15
MAX_EXTRACTED_MB=75
MAX_FILE_MB=10
MAX_FILES=1500

# Current GitHub REST API version
GITHUB_API_VERSION=2026-03-10
PORT=3000
